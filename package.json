{
  "name": "ipl-test-framework",
  "version": "1.0.0",
  "description": "Cypress and Playwright test framework for IPL T20 points table scraping",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:ipl": "cypress run --spec 'cypress/e2e/youtube/search.cy.js'",
    "pw:install": "playwright install",
    "pw:test": "playwright test",
    "pw:test:ipl": "playwright test playwright/tests/youtube/search.spec.js",
    "pw:report": "playwright show-report",
    "cy:merge-reports": "mochawesome-merge cypress/reports/*.json > cypress/reports/merged.json",
    "cy:generate-report": "marge cypress/reports/merged.json -f report -o cypress/reports/html",
    "cy:report": "npm run cy:merge-reports && npm run cy:generate-report"

  },
  "devDependencies": {
    "@playwright/test": "^1.43.0",
    "cypress": "^13.6.0",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2"
  }
}
